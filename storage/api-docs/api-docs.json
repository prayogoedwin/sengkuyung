        "api/pendataan/{id}/upload": {
            "post": {
                "tags": [
                    "Pendataan Kendaraan"
                ],
                "summary": "Upload berkas pendataan (mendukung enkripsi untuk KTP)",
                "operationId": "fa2d9de16ae0f7a1795ec5e0b62dd914",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Encoded ID pendataan",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "file_ke",
                                    "file",
                                    "keterangan"
                                ],
                                "properties": {
                                    "file_ke": {
                                        "type": "string",
                                        "example": "file0",
                                        "enum": [
                                            "file0",
                                            "file1",
                                            "file2",
                                            "file3",
                                            "file4",
                                            "file5",
                                            "file6",
                                            "file7",
                                            "file8",
                                            "file9"
                                        ]
                                    },
                                    "keterangan": {
                                        "description": "Jika bernilai KTP, file disimpan terenkripsi",
                                        "type": "string",
                                        "example": "KTP"
                                    },
                                    "file": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "File berhasil diunggah"
