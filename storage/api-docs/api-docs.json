{
    "openapi": "3.0.0",
    "info": {
        "title": "Sengkuyung API",
        "description": "Dokumentasi API untuk aplikasi Sengkuyung.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Server utama"
        }
    ],
    "paths": {
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login menggunakan email dan password",
                "operationId": "97161f393db7be9187637d9afc9c9619",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "petugas@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "rahasia123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Login successful"
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "1|abcdeFGHIJKLmnOPqrSTUvwxYZ"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthorized"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/login_with_otp": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login dan generate OTP",
                "operationId": "cf0c4d94b3dfbadd8728e67fd2323152",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password",
                                    "otp_method"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "petugas@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "rahasia123"
                                    },
                                    "otp_method": {
                                        "type": "string",
                                        "example": "email",
                                        "enum": [
                                            "email",
                                            "wa"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OTP berhasil digenerate",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "OTP Tergenerate, dengan expire 5 menit"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "/api/verifikasi_otp": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Verifikasi OTP untuk login",
                "operationId": "1c2216a573e1c32e079ec3d57258281f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "otp"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "petugas@example.com"
                                    },
                                    "otp": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OTP valid, login berhasil"
                    },
                    "401": {
                        "description": "OTP invalid/expired"
                    }
                }
            }
        },
        "/api/update_password": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Ubah password user",
                "operationId": "e3b60b09473f5b66c1712bbd6d2700c4",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id",
                                    "password_baru",
                                    "konfirmasi_password"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "string",
                                        "example": "VXNlcjox"
                                    },
                                    "password_baru": {
                                        "type": "string",
                                        "example": "passwordBaru123"
                                    },
                                    "konfirmasi_password": {
                                        "type": "string",
                                        "example": "passwordBaru123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Password berhasil diubah"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "Masukkan token hasil login dalam format: Bearer {token}",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        }
    ]
}