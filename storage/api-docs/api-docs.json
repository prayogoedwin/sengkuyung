{
    "openapi": "3.0.0",
    "info": {
        "title": "Sengkuyung API",
        "description": "Dokumentasi API untuk aplikasi Sengkuyung.",
        "version": "1.0.0"
    },
    "paths": {
        "api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login menggunakan email dan password",
                "operationId": "2ed6dc5febcb13bc773fd496c2bbb3f3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "petugas@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "rahasia123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Login successful"
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "1|abcdeFGHIJKLmnOPqrSTUvwxYZ"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthorized"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "api/login_with_otp": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login dan generate OTP",
                "operationId": "9abedaabe48c385bd2d01b664d6f6410",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password",
                                    "otp_method"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "petugas@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "rahasia123"
                                    },
                                    "otp_method": {
                                        "type": "string",
                                        "example": "email",
                                        "enum": [
                                            "email",
                                            "wa"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OTP berhasil digenerate",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "OTP Tergenerate, dengan expire 5 menit"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "api/verifikasi_otp": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Verifikasi OTP untuk login",
                "operationId": "4c556362188351921fe864571775551d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "otp"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "petugas@example.com"
                                    },
                                    "otp": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OTP valid, login berhasil"
                    },
                    "401": {
                        "description": "OTP invalid/expired"
                    }
                }
            }
        },
        "api/update_password": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Ubah password user",
                "operationId": "595f82615ef7e54b14580c711be10263",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id",
                                    "password_baru",
                                    "konfirmasi_password"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "string",
                                        "example": "VXNlcjox"
                                    },
                                    "password_baru": {
                                        "type": "string",
                                        "example": "passwordBaru123"
                                    },
                                    "konfirmasi_password": {
                                        "type": "string",
                                        "example": "passwordBaru123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Password berhasil diubah"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "api/data-tertagih/list": {
            "post": {
                "tags": [
                    "Data Tertagih"
                ],
                "summary": "Daftar data tertagih (is_terdata=0) dengan filter wilayah samsat + tahun + nopol",
                "operationId": "e76a50a2d0e4d28883640c2c0cac086e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "lokasi_samsat",
                                    "kecamatan_samsat",
                                    "kelurahan_samsat"
                                ],
                                "properties": {
                                    "lokasi_samsat": {
                                        "description": "Wajib. Dipetakan ke id_lokasi_samsat (sama seperti di response login user).",
                                        "type": "string",
                                        "example": "01"
                                    },
                                    "kecamatan_samsat": {
                                        "description": "Wajib. Dipetakan ke id_kecamatan.",
                                        "type": "string",
                                        "example": "0105"
                                    },
                                    "kelurahan_samsat": {
                                        "description": "Wajib. Dipetakan ke id_kelurahan.",
                                        "type": "string",
                                        "example": "0105007"
                                    },
                                    "year": {
                                        "description": "Opsional. Default tahun berjalan.",
                                        "type": "integer",
                                        "example": 2026
                                    },
                                    "no_polisi": {
                                        "description": "Opsional. Pencarian LIKE pada no_polisi.",
                                        "type": "string",
                                        "example": "H8121QY"
                                    },
                                    "page": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "per_page": {
                                        "type": "integer",
                                        "example": 15
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Data ditemukan"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "pagination": {
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "example": 15
                                                },
                                                "total": {
                                                    "type": "integer",
                                                    "example": 120
                                                },
                                                "last_page": {
                                                    "type": "integer",
                                                    "example": 8
                                                },
                                                "from": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "to": {
                                                    "type": "integer",
                                                    "example": 15
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "Masukkan token hasil login dalam format: Bearer {token}",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Data Tertagih",
            "description": "Data Tertagih"
        }
    ]
}