{
    "openapi": "3.0.0",
    "info": {
        "title": "Sengkuyung API",
        "description": "Dokumentasi API untuk aplikasi Sengkuyung.",
        "version": "1.0.0"
    },
    "paths": {
        "api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login menggunakan email dan password",
                "operationId": "2ed6dc5febcb13bc773fd496c2bbb3f3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "petugas@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "rahasia123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Login successful"
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "1|abcdeFGHIJKLmnOPqrSTUvwxYZ"
                                        },
                                        "data": {
                                            "description": "Profil user. lokasi_samsat_name, kecamatan_samsat_name, kelurahan_samsat_name diisi dari lookup (bukan kolom users).",
                                            "properties": {
                                                "lokasi_samsat_name": {
                                                    "type": "string",
                                                    "example": "SAMSAT Gayamsari",
                                                    "nullable": true
                                                },
                                                "kecamatan_samsat_name": {
                                                    "type": "string",
                                                    "example": "Gayamsari",
                                                    "nullable": true
                                                },
                                                "kelurahan_samsat_name": {
                                                    "type": "string",
                                                    "example": "Gayamsari",
                                                    "nullable": true
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthorized"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "api/login_with_otp": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login dan generate OTP",
                "operationId": "9abedaabe48c385bd2d01b664d6f6410",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password",
                                    "otp_method"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "petugas@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "rahasia123"
                                    },
                                    "otp_method": {
                                        "type": "string",
                                        "example": "email",
                                        "enum": [
                                            "email",
                                            "wa"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OTP berhasil digenerate",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "OTP Tergenerate, dengan expire 5 menit"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
        "api/verifikasi_otp": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Verifikasi OTP untuk login",
                "operationId": "4c556362188351921fe864571775551d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "otp"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "petugas@example.com"
                                    },
                                    "otp": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OTP valid, login berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Login successful"
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "1|abcdeFGHIJKLmnOPqrSTUvwxYZ"
                                        },
                                        "data": {
                                            "description": "Sama seperti api/login; nama samsat/kec/kel hanya di response.",
                                            "properties": {
                                                "lokasi_samsat_name": {
                                                    "type": "string",
                                                    "nullable": true
                                                },
                                                "kecamatan_samsat_name": {
                                                    "type": "string",
                                                    "nullable": true
                                                },
                                                "kelurahan_samsat_name": {
                                                    "type": "string",
                                                    "nullable": true
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "OTP invalid/expired"
                    }
                }
            }
        },
        "api/update_password": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Ubah password user",
                "operationId": "595f82615ef7e54b14580c711be10263",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id",
                                    "password_baru",
                                    "konfirmasi_password"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "string",
                                        "example": "VXNlcjox"
                                    },
                                    "password_baru": {
                                        "type": "string",
                                        "example": "passwordBaru123"
                                    },
                                    "konfirmasi_password": {
                                        "type": "string",
                                        "example": "passwordBaru123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Password berhasil diubah"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "api/data-tertagih/list": {
            "post": {
                "tags": [
                    "Data Tertagih"
                ],
                "summary": "Daftar data tertagih (is_terdata=0) dengan filter wilayah samsat + tahun + nopol",
                "operationId": "e76a50a2d0e4d28883640c2c0cac086e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "lokasi_samsat",
                                    "kecamatan_samsat",
                                    "kelurahan_samsat"
                                ],
                                "properties": {
                                    "lokasi_samsat": {
                                        "description": "Wajib. Dicocokkan ke id_lokasi_samsat (nilai asli + tanpa leading zero, mis. 01 dan 1).",
                                        "type": "string",
                                        "example": "01"
                                    },
                                    "kecamatan_samsat": {
                                        "description": "Wajib. Dicocokkan ke id_kecamatan (mis. 0105 dan 105).",
                                        "type": "string",
                                        "example": "0105"
                                    },
                                    "kelurahan_samsat": {
                                        "description": "Wajib. Dicocokkan ke id_kelurahan (mis. 0105007 dan 105007).",
                                        "type": "string",
                                        "example": "0105007"
                                    },
                                    "year": {
                                        "description": "Opsional. Default tahun berjalan.",
                                        "type": "integer",
                                        "example": 2026
                                    },
                                    "no_polisi": {
                                        "description": "Opsional. Pencarian LIKE pada no_polisi.",
                                        "type": "string",
                                        "example": "H8121QY"
                                    },
                                    "page": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "per_page": {
                                        "type": "integer",
                                        "example": 15
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Data ditemukan"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "pagination": {
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "example": 15
                                                },
                                                "total": {
                                                    "type": "integer",
                                                    "example": 120
                                                },
                                                "last_page": {
                                                    "type": "integer",
                                                    "example": 8
                                                },
                                                "from": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "to": {
                                                    "type": "integer",
                                                    "example": 15
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "api/data-tertagih/{id}": {
            "get": {
                "tags": [
                    "Data Tertagih"
                ],
                "summary": "Detail data tertagih by id + cek apakah nopol sudah didata user lain",
                "operationId": "70c97b4bb4642b779b0fa9469efa925c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID data_tertagih",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Data ditemukan"
                                        },
                                        "data": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 12
                                                },
                                                "no_polisi": {
                                                    "type": "string",
                                                    "example": "H-8121-QY"
                                                },
                                                "can_select": {
                                                    "type": "boolean",
                                                    "example": false
                                                },
                                                "warning_message": {
                                                    "type": "string",
                                                    "example": "Nopol ini tidak bisa dipilih, karena sudah didata oleh user lain.",
                                                    "nullable": true
                                                },
                                                "pendataan": {
                                                    "type": "object",
                                                    "nullable": true
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "404": {
                        "description": "Data tidak ditemukan"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "api/pendataan": {
            "get": {
                "tags": [
                    "Pendataan Kendaraan"
                ],
                "summary": "List pendataan kendaraan milik user login",
                "operationId": "6dfb9b023c0dafc0c0a2e65d16faba6d",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Jumlah data per halaman",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Nomor halaman",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil mendapatkan daftar data",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "List data ditemukan"
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "pagination": {
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "last_page": {
                                                    "type": "integer",
                                                    "example": 10
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "example": 10
                                                },
                                                "total": {
                                                    "type": "integer",
                                                    "example": 100
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Pendataan Kendaraan"
                ],
                "summary": "Tambah data pendataan kendaraan",
                "operationId": "e4f81b2b0430c1bff4030cddc34cac70",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nohp",
                                    "nopol",
                                    "nama",
                                    "alamat",
                                    "status",
                                    "status_verifikasi",
                                    "kota",
                                    "kec"
                                ],
                                "properties": {
                                    "nohp": {
                                        "type": "string",
                                        "example": "081234567890"
                                    },
                                    "nopol": {
                                        "type": "string",
                                        "example": "H1234AB"
                                    },
                                    "nama": {
                                        "type": "string",
                                        "example": "Budi Santoso"
                                    },
                                    "alamat": {
                                        "type": "string",
                                        "example": "Jl. Merdeka No. 1"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "budi@mail.com",
                                        "nullable": true
                                    },
                                    "nik": {
                                        "description": "Wajib jika status mengarah ke data dengan KTP",
                                        "type": "string",
                                        "example": "3374010101010001",
                                        "nullable": true
                                    },
                                    "status": {
                                        "description": "Encoded ID status",
                                        "type": "string",
                                        "example": "VXNlcjox"
                                    },
                                    "status_verifikasi": {
                                        "description": "Encoded ID status verifikasi",
                                        "type": "string",
                                        "example": "VXNlcjo1"
                                    },
                                    "kota": {
                                        "type": "string",
                                        "example": "01"
                                    },
                                    "kec": {
                                        "type": "string",
                                        "example": "3374010"
                                    },
                                    "desa_name": {
                                        "type": "string",
                                        "example": "Tembalang",
                                        "nullable": true
                                    },
                                    "kec_name": {
                                        "type": "string",
                                        "example": "Tembalang",
                                        "nullable": true
                                    },
                                    "kota_name": {
                                        "type": "string",
                                        "example": "Semarang",
                                        "nullable": true
                                    },
                                    "merk": {
                                        "type": "string",
                                        "example": "Honda",
                                        "nullable": true
                                    },
                                    "tipe": {
                                        "type": "string",
                                        "example": "Beat",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Data berhasil ditambahkan"
                    },
                    "400": {
                        "description": "Validasi gagal / data tidak valid"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
